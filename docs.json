{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hanalyx Docs",
  "colors": {
    "primary": "#004AAD",
    "light": "#1A5FBD",
    "dark": "#003D91"
  },
  "background": {
    "color": {
      "light": "#FAFAFA",
      "dark": "#020202"
    }
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "weight": 700
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Kensa",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "kensa/index",
              "kensa/quickstart"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "kensa/cli-reference",
              "kensa/configuration",
              "kensa/frameworks",
              "kensa/output-formats"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "kensa/remediation",
              "kensa/auditor-guide"
            ]
          }
        ]
      },
      {
        "tab": "OpenWatch",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "openwatch/index",
              "openwatch/quickstart",
              "openwatch/installation"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "openwatch/scanning",
              "openwatch/hosts-and-remediation",
              "openwatch/user-roles"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "openwatch/api-guide"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://github.com/Hanalyx",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@hanalyx.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/Hanalyx"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/hanalyx",
      "github": "https://github.com/Hanalyx",
      "linkedin": "https://www.linkedin.com/company/hanalyx"
    }
  }
}
